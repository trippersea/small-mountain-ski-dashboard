{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/about.html",
      "destination": "/about",
      "permanent": true
    },
    {
      "source": "/report/:slug",
      "destination": "/ski-report/:slug",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/ski-report/:slug", "destination": "/ski-report/:slug/index.html" },
    { "source": "/ski/:state", "destination": "/ski/:state/index.html" }
  ]
}
