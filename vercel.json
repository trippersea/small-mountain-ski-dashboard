{
  "rewrites": [
    {
      "source": "/report/:slug",
      "destination": "/ski-report/:slug/"
    }
  ],
  "redirects": [
    {
      "source": "/about.html",
      "destination": "/about/",
      "permanent": true
    }
  ],
  "routes": [
    {
      "src": "/ski-report/([^/]+)/?$",
      "dest": "/ski-report/$1/index.html"
    },
    {
      "src": "/ski/([^/]+)/?$",
      "dest": "/ski/$1/index.html"
    },
    {
      "src": "/about/?$",
      "dest": "/about.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1",
      "status": 200,
      "continue": true
    },
    {
      "src": "/(.*)",
      "dest": "/404.html",
      "status": 404
    }
  ]
}
